#!/bin/bash

#What are conditionals?

#A conditonal checks if something is true or false then runs code based on the result

#How it works:

#Conditonals are used inside brackets 
#if > starts the check
#then > begings the code block
#else > optional fallback
#fi ends the conditional

#Common mistakes:

#Forgetting spaces inside brackets, ex. if[$grade = "A"]; then
#Forgetting to finish your line with then, ex. if [ "$grade" = "A" ]
#Forgetting to end code with fi, ex. if [ "$grade" = "A" ]; then echo "W grade"
#Not quoting variables, ex. if [ $name = Sadeeq ]; then

#How to troubleshoot the mistakes:

#Add spaces where needed, ex. if[ $grade = "A" ]; then
#Add a then at the end of the line, ex. if [ "$grade" = "A" ]; then
#Forgetting to end code with fi, ex. if [ "$grade" = "A" ]; then echo "W grade"
#Add the correct quotation depending on the context, ex. [ "$name" = "Sadeeq" ]; then

grade="A"

if [ "$grade" = "A" ]; then
  echo "W grade"
elif [ "$grade" = "B" ]; then
  echo "Good job"
elif [ "$grade" = "C" ]; then
  echo "At least push for a B"
else
  echo "Chai"
fi

